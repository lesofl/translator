{
  "manifest_version": 3,
  "name": "Lingua",
  "version": "2.0.0",
  "description": "Offline page translator powered by LibreTranslate.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:*/*",
    "http://localhost:*/*"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Translate Page"
  },
  "content_scripts": [],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
